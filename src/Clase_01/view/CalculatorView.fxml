<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>
<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/26"
      fx:controller="Clase_01.controller.CalculatorController"
      alignment="CENTER"
      spacing="15.0"
      styleClass="main-container">

    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
    </padding>

    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <Label text="Calculadora Básica" styleClass="title-label"/>

    <TextField fx:id="inputNumber1" promptText="First number" styleClass="number-input"/>
    <TextField fx:id="inputNumber2" promptText="Second number" styleClass="number-input"/>

    <HBox alignment="CENTER" spacing="10.0">
        <Button text="+" onAction="#onAddClick" styleClass="op-button"/>
        <Button text="-" onAction="#onSubtractClick" styleClass="op-button"/>
        <Button text="*" onAction="#onMultiplyClick" styleClass="op-button"/>
        <Button text="/" onAction="#onDivideClick" styleClass="op-button"/>
    </HBox>

    <Button text="Clear All" onAction="#onClearClick" styleClass="clear-button"/>

    <Label text="Result:" styleClass="result-title-label"/>
    <Label fx:id="labelResult" text="0.0" styleClass="result-value-label"/>

</VBox>