<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>
<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/25"
      fx:controller="Clase_05.Correction.Client.UI.controller.CreateViewController"
      alignment="CENTER"
      spacing="20.0"
      prefHeight="600.0"
      prefWidth="650.0"
      styleClass="main-background">

    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <VBox alignment="CENTER" spacing="5.0">
        <Label text="SISTEMA METROPOLITANO DE TRANSPORTE" styleClass="header-subtitle"/>
        <Label text="Registro de Nuevo Usuario" styleClass="header-title"/>
    </VBox>

    <VBox alignment="CENTER" spacing="20.0" styleClass="content-card" maxWidth="550.0">

        <GridPane hgap="20.0" vgap="15.0" alignment="CENTER">
            <columnConstraints>
                <ColumnConstraints percentWidth="50.0"/>
                <ColumnConstraints percentWidth="50.0"/>
            </columnConstraints>

            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Nombres" styleClass="form-label"/>
                <TextField fx:id="txt_field_name" promptText="Ej: Juan Diego" styleClass="input-field"/>
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Apellidos" styleClass="form-label"/>
                <TextField fx:id="txt_field_lastname" promptText="Ej: Pérez Silva" styleClass="input-field"/>
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="Número de Cédula" styleClass="form-label"/>
                <TextField fx:id="txt_field_identification" promptText="Ej: 1712345678" styleClass="input-field"/>
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="Fecha de Nacimiento" styleClass="form-label"/>
                <DatePicker fx:id="date_picker_birth" promptText="DD/MM/AAAA" styleClass="modern-date-picker" maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <Label text="Correo Electrónico" styleClass="form-label"/>
                <TextField fx:id="txt_field_mail" promptText="ejemplo@correo.com" styleClass="input-field"/>
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <Label text="Teléfono Móvil" styleClass="form-label"/>
                <TextField fx:id="txt_field_phone" promptText="Ej: 0991234567" styleClass="input-field"/>
            </VBox>
        </GridPane>

        <Label fx:id="lbl_result_query" styleClass="result-label" wrapText="true" textAlignment="CENTER"/>

        <HBox alignment="CENTER" spacing="15.0" styleClass="action-bar">
            <Button mnemonicParsing="false" text="CANCELAR" styleClass="btn-secondary"/>
            <Button mnemonicParsing="false" onAction="#createUser" text="CREAR USUARIO" styleClass="btn-primary"/>
        </HBox>
    </VBox>
</VBox>