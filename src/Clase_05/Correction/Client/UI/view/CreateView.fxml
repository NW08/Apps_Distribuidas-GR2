<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>
<VBox xmlns:fx="http://javafx.com/fxml/1" alignment="CENTER" prefHeight="600.0" prefWidth="650.0" spacing="20.0"
      styleClass="main-background" xmlns="http://javafx.com/javafx/26"
      fx:controller="Clase_05.Correction.Client.UI.controller.CreateController">

    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <VBox alignment="CENTER" spacing="5.0">
        <Label styleClass="header-subtitle" text="SISTEMA METROPOLITANO DE TRANSPORTE"/>
        <Label styleClass="header-title" text="Registro de Nuevo Usuario"/>
    </VBox>

    <VBox alignment="CENTER" maxWidth="550.0" spacing="20.0" styleClass="content-card">

        <GridPane alignment="CENTER" hgap="20.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints percentWidth="50.0"/>
                <ColumnConstraints percentWidth="50.0"/>
            </columnConstraints>

            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label styleClass="form-label" text="Nombres"/>
                <TextField fx:id="txt_field_name" promptText="Ej: Juan Diego" styleClass="input-field"/>
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label styleClass="form-label" text="Apellidos"/>
                <TextField fx:id="txt_field_lastname" promptText="Ej: Pérez Silva" styleClass="input-field"/>
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label styleClass="form-label" text="Número de Cédula"/>
                <TextField fx:id="txt_field_identification" promptText="Ej: 1712345678" styleClass="input-field"/>
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label styleClass="form-label" text="Fecha de Nacimiento"/>
                <DatePicker fx:id="date_picker_birth" maxWidth="Infinity" promptText="DD/MM/AAAA" styleClass="modern-date-picker"/>
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <Label styleClass="form-label" text="Correo Electrónico"/>
                <TextField fx:id="txt_field_mail" promptText="ejemplo@correo.com" styleClass="input-field"/>
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <Label styleClass="form-label" text="Teléfono Móvil"/>
                <TextField fx:id="txt_field_phone" promptText="Ej: 0991234567" styleClass="input-field"/>
            </VBox>
            <rowConstraints>
                <RowConstraints/>
                <RowConstraints/>
                <RowConstraints/>
            </rowConstraints>
        </GridPane>

        <Label fx:id="lbl_result_query" styleClass="result-label" textAlignment="CENTER" wrapText="true"/>

        <HBox alignment="CENTER" spacing="15.0" styleClass="action-bar">
            <Button mnemonicParsing="false" onAction="#cancelOperation" styleClass="btn-secondary" text="VOLVER"/>
            <Button fx:id="btn_create" mnemonicParsing="false" onAction="#createUser" styleClass="btn-primary" text="CREAR USUARIO"/>
        </HBox>
    </VBox>
</VBox>
