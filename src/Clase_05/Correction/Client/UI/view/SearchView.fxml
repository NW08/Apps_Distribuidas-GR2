<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="Clase_05.Correction.Client.UI.controller.SearchController"
    alignment="CENTER"
    prefHeight="600.0"
    prefWidth="600.0"
    spacing="25.0"
    styleClass="main-background"
    xmlns="http://javafx.com/javafx/26"
    xmlns:fx="http://javafx.com/fxml/1">

    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>

    <VBox alignment="CENTER" spacing="5.0">
        <Label styleClass="header-subtitle" text="SISTEMA METROPOLITANO DE TRANSPORTE" />
        <Label styleClass="header-title" text="Gestión de Tarjetas" />
        <Label styleClass="udp-badge" text="Cliente UDP" />
    </VBox>

    <VBox alignment="CENTER" maxWidth="450.0" spacing="20.0" styleClass="content-card">
        <Label styleClass="prompt-label" text="Ingresa tu número de cédula:" />

        <TextField fx:id="txt_field_identification" maxWidth="320.0" promptText="Ej: 1712345678" styleClass="input-field" />

        <Label fx:id="lbl_query_result" styleClass="result-label" textAlignment="CENTER" wrapText="true" />

        <HBox alignment="CENTER" spacing="15.0" styleClass="action-bar">
            <Button fx:id="btn_search" mnemonicParsing="false" onAction="#searchUser" styleClass="btn-primary" text="BUSCAR" />
            <Button fx:id="btn_newUser" mnemonicParsing="false" onAction="#registerUser" styleClass="btn-secondary" text="NUEVO USUARIO" />
        </HBox>
    </VBox>
</VBox>